apiVersion: kubectl.config.k8s.io/v1beta1
kind: Preference

aliases:
  # --- get shortcuts ---
  - name: kgp
    command: get
    prependArgs: [pods]

  - name: kgs
    command: get
    prependArgs: [services]

  - name: kgd
    command: get
    prependArgs: [deployments]

  - name: kgn
    command: get
    prependArgs: [nodes]

  - name: kga
    command: get
    prependArgs: [all]

  # --- watch ---
  - name: kwatch
    command: get
    prependArgs: [pods]
    options:
      - name: watch
        default: "true"

  # --- describe ---
  - name: kdp
    command: describe
    prependArgs: [pod]

  - name: kdd
    command: describe
    prependArgs: [deployment]

  # --- logs ---
  - name: kl
    command: logs
    options:
      - name: follow
        default: "true"

  - name: klp
    command: logs
    options:
      - name: follow
        default: "true"
      - name: previous
        default: "true"

  # --- apply / delete ---
  - name: kaf
    command: apply
    prependArgs: ["-f"]

  - name: kdf
    command: delete
    prependArgs: ["-f"]

  # --- exec ---
  - name: kex
    command: exec
    options:
      - name: stdin
        default: "true"
      - name: tty
        default: "true"

  # --- debug: events sorted by time (most useful for incident response) ---
  - name: kev
    command: get
    prependArgs: [events]
    options:
      - name: sort-by
        default: ".lastTimestamp"

  # --- debug: resource usage ---
  - name: ktop
    command: top
    prependArgs: [pods]
    options:
      - name: sort-by
        default: "cpu"

  - name: ktopn
    command: top
    prependArgs: [nodes]

  # --- debug: pods sorted by restart count ---
  - name: krestart
    command: get
    prependArgs: [pods]
    options:
      - name: sort-by
        default: ".status.containerStatuses[0].restartCount"

defaults:
  - command: get
    options:
      - name: output
        default: wide
